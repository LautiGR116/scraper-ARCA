# Copy this file to .env and fill in your own credentials.
# Never commit .env to version control.

# Your CUIT/CUIL (11 digits, with or without dashes)
ARCA_CUIT=20123456789

# Your Clave Fiscal password
ARCA_PASSWORD=your_password_here

# Directory where CSV files are written (default: output/)
OUTPUT_DIR=output

# Maximum concurrent scrapers for the batch API endpoint (default: 5)
MAX_CONCURRENT_SCRAPERS=5
